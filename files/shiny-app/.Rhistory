})
# Load the SpatRaster object
# The app assumes "isotic-env-raster-stack.tif" is in the same directory as app.R
# This line assumes you have the file "shiny-app/isotic-env-raster-stack.tif"
# available when running the app.
tryCatch({
my_stack <- rast("isotic-p-round.tif")
names(decision_raster) <- "Isotic Probability"
}, error = function(e) {
# Add the error message to the stop function for better debugging
stop(paste("Error loading the raster filePlease ensure 'shiny-app/isotic-p-round.tif' is present in your app's directory."))
})
